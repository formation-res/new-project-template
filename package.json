{
  "name": "new-project-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@12.0.1",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "setup": "node scripts/setup-project.mjs",
    "setup:check": "node scripts/check-project-setup.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "timestamp:update": "node scripts/update-template-timestamp.mjs",
    "timestamp:check": "node scripts/update-template-timestamp.mjs --check",
    "assets:check": "node scripts/check-assets.mjs",
    "deploy:smoke": "node scripts/smoke-deployment.mjs",
    "translations:check": "node scripts/check-translations.mjs",
    "translations:sync": "node scripts/sync-translations.mjs",
    "check": "npm run lint && npm run typecheck && npm run setup:check && npm run timestamp:check && npm run translations:check && npm run assets:check && npm run test && npm run build",
    "check:all": "npm run check && npm run test:e2e"
  },
  "dependencies": {
    "@fluent/bundle": "^0.19.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "daisyui": "^5.7.0",
    "jsdom": "^29.1.1",
    "openai": "^6.48.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.113.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true,
    "sharp@0.34.5": true,
    "workerd@1.20260721.1": true
  }
}
