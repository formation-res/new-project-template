{
  "name": "new-project-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "setup": "node scripts/setup-project.mjs",
    "setup:check": "node scripts/check-project-setup.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "timestamp:update": "node scripts/update-template-timestamp.mjs",
    "timestamp:check": "node scripts/update-template-timestamp.mjs --check",
    "assets:check": "node scripts/check-assets.mjs",
    "deploy:smoke": "node scripts/smoke-deployment.mjs",
    "translations:check": "node scripts/check-translations.mjs",
    "translations:sync": "node scripts/sync-translations.mjs",
    "check": "npm run lint && npm run typecheck && npm run setup:check && npm run timestamp:check && npm run translations:check && npm run assets:check && npm run test && npm run build",
    "check:all": "npm run check && npm run test:e2e"
  },
  "dependencies": {
    "@fluent/bundle": "^0.19.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "daisyui": "^5.5.19",
    "jsdom": "^29.0.1",
    "openai": "^6.46.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.110.0"
  }
}
